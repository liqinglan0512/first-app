# Runtime mode: development or production.
CMS_ENV=development

# Use a strong random value of at least 32 bytes in production.
CMS_AUTH_SECRET=change-me

# SQLite is suitable for local development. Production may use postgresql://.
CMS_DATABASE_URL=sqlite:///data/mechanics.db
CMS_DATA_DIR=data

# Production HTTPS deployments must keep this enabled.
CMS_COOKIE_SECURE=false

# Reserved for the entitlement phase. Never commit the real value.
CMS_INTERNAL_INVITE_CODE=change-me
CMS_INTERNAL_INVITE_TTL_DAYS=90
CMS_INTERNAL_INVITE_USER_LIMIT=5
CMS_INTERNAL_INVITE_ADDRESS_LIMIT=20
